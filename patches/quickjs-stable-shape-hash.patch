diff --git a/quickjs.c b/quickjs.c
index 991f0a6..e9f8ed6 100644
--- a/quickjs.c
+++ b/quickjs.c
@@ -5197,9 +5197,12 @@ static uint32_t get_shape_hash(uint32_t h, int hash_bits)
 static uint32_t shape_initial_hash(JSObject *proto)
 {
     uint32_t h;
-    h = shape_hash(1, (uintptr_t)proto);
