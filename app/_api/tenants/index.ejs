<%
  if (request.method === "GET") {
    let tenants = [];
    let raw = kv.range("__tenants/", "__tenants/\x7f", 100);
    if (raw) {
      for (let entry of raw) {
        tenants.push(JSON.parse(entry.value));
      }
    }
    return { tenants };
  }

  if (request.method === "POST") {
    let body = JSON.parse(request.body);
    let name = (body.name || "").trim();
    if (!name) {
      response.status(400);
      return { error: "name is required" };
    }

    // Find next tenant ID
    let tenants = [];
    let raw = kv.range("__tenants/", "__tenants/\x7f", 100);
    if (raw) {
      for (let entry of raw) {
        tenants.push(JSON.parse(entry.value));
      }
    }

    let nextId = 1;
    for (let t of tenants) {
      if (t.id >= nextId) nextId = t.id + 1;
    }

    let meta = { id: nextId, name: name };
    kv.put("__tenants/" + nextId, JSON.stringify(meta));
    kv.put("tenants/" + nextId + "/__code/index.ejs", '<h1>Hello, world!</h1>\n<p>Your new tenant is ready.</p>');

    return { tenant: meta };
  }

  if (request.method === "DELETE") {
    let body = JSON.parse(request.body);
    let id = body.id;
    if (!id) {
      response.status(400);
      return { error: "id is required" };
    }
    kv.delete("__tenants/" + id);
    return { ok: true };
  }

  response.status(405);
  return { error: "method not allowed" };
%>
