<%
  if (request.method === "GET") {
    // GET with ?path=foo reads a single module, otherwise lists all
    let qs = request.path.split("?")[1] || "";
    let params = {};
    for (let p of qs.split("&")) {
      let [k, v] = p.split("=");
      if (k && v) params[k] = decodeURIComponent(v);
    }

    if (params.path) {
      let content = code.get(params.path);
      if (content === undefined || content === null) {
        response.status(404);
        return { error: "not found" };
      }
      return { path: params.path, content };
    }

    return { files: code.list() };
  }

  if (request.method === "POST") {
    let body = JSON.parse(request.body);
    let path = (body.path || "").trim();
    if (!path) {
      response.status(400);
      return { error: "path is required" };
    }

    let content = body.content;
    if (content === undefined || content === null) {
      response.status(400);
      return { error: "content is required" };
    }

    code.put(path, content);
    return { ok: true };
  }

  if (request.method === "DELETE") {
    let body = JSON.parse(request.body);
    let path = (body.path || "").trim();
    if (!path) {
      response.status(400);
      return { error: "path is required" };
    }

    code.delete(path);
    return { ok: true };
  }

  response.status(405);
  return { error: "method not allowed" };
%>
