<%
  // API: POST with action "load" or "save"
  if (request.method === "POST") {
    let body = JSON.parse(request.body);

    if (body.action === "list") {
      let files = [];
      let raw = kv.range("__code/", "__code/\x7f", 10000);
      if (raw) {
        for (let entry of raw) {
          files.push(entry.key.slice(7)); // strip "__code/"
        }
      }
      return { files };
    }

    if (body.action === "load") {
      let content = kv.get("__code/" + body.path);
      if (content === undefined || content === null) {
        response.status(404);
        return { error: "not found" };
      }
      return { content };
    }

    if (body.action === "save") {
      kv.put("__code/" + body.path, body.content);
      // Invalidate compiled bytecode cache
      let base = body.path;
      let dot = base.lastIndexOf(".");
      let slash = base.lastIndexOf("/");
      if (dot > slash) base = base.substring(0, dot);
      kv.delete("__compiled/" + base);
      return { ok: true };
    }

    if (body.action === "delete") {
      kv.delete("__code/" + body.path);
      let base = body.path;
      let dot = base.lastIndexOf(".");
      let slash = base.lastIndexOf("/");
      if (dot > slash) base = base.substring(0, dot);
      kv.delete("__compiled/" + base);
      return { ok: true };
    }

    response.status(400);
    return { error: "unknown action" };
  }

  // GET: collect file list for initial render
  let files = [];
  let raw = kv.range("__code/", "__code/\x7f", 10000);
  if (raw) {
    for (let entry of raw) {
      files.push(entry.key.slice(7));
    }
  }
%>
<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Editor - shift-js admin</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/codemirror.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/theme/dracula.min.css">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; overflow: hidden; font-family: system-ui, sans-serif; background: #1e1e2e; color: #cdd6f4; }

    .toolbar { display: flex; align-items: center; gap: 1rem; padding: 0.5rem 1rem; background: #181825; border-bottom: 1px solid #313244; height: 44px; }
    .toolbar a { color: #89b4fa; text-decoration: none; font-weight: 500; font-size: 0.9rem; }
    .toolbar a:hover { text-decoration: underline; }
    .toolbar .title { font-weight: 600; font-size: 0.95rem; color: #cdd6f4; }
    .toolbar .filepath { color: #a6adc8; font-size: 0.85rem; font-family: monospace; margin-left: auto; }
    .toolbar button { padding: 0.3rem 0.9rem; border: none; border-radius: 4px; font-size: 0.85rem; cursor: pointer; font-weight: 500; }
    .btn-save { background: #89b4fa; color: #1e1e2e; }
    .btn-save:hover { background: #74c7ec; }
    .btn-save:disabled { opacity: 0.4; cursor: default; }
    .btn-new { background: #313244; color: #cdd6f4; }
    .btn-new:hover { background: #45475a; }
    .btn-delete { background: none; color: #f38ba8; border: 1px solid #f38ba8; }
    .btn-delete:hover { background: #31224455; }
    .saved-indicator { font-size: 0.8rem; color: #a6e3a1; opacity: 0; transition: opacity 0.3s; }
    .saved-indicator.show { opacity: 1; }

    .main { display: flex; height: calc(100% - 44px); }

    .sidebar { width: 260px; min-width: 200px; background: #181825; border-right: 1px solid #313244; overflow-y: auto; flex-shrink: 0; }
    .sidebar .section-label { font-size: 0.7rem; text-transform: uppercase; color: #6c7086; padding: 0.75rem 1rem 0.25rem; font-weight: 600; letter-spacing: 0.05em; }

    .tree { font-size: 0.85rem; }
    .tree-item { display: flex; align-items: center; padding: 0.25rem 0.5rem; cursor: pointer; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .tree-item:hover { background: #313244; }
    .tree-item.active { background: #45475a; color: #89b4fa; }
    .tree-dir { color: #a6adc8; font-weight: 500; user-select: none; }
    .tree-file { color: #cdd6f4; }
    .tree-icon { width: 1.2em; text-align: center; margin-right: 0.3rem; flex-shrink: 0; font-size: 0.8rem; }
    .tree-children { display: none; }
    .tree-children.open { display: block; }
    .tree-item.collapsed .tree-icon.dir-icon::before { content: "\25b6"; }
    .tree-item:not(.collapsed) .tree-icon.dir-icon::before { content: "\25be"; }
    .tree-icon.file-icon::before { content: "\25cb"; font-size: 0.6rem; }

    .editor-pane { flex: 1; display: flex; flex-direction: column; min-width: 0; }
    .editor-pane .empty-state { display: flex; align-items: center; justify-content: center; height: 100%; color: #6c7086; font-size: 0.95rem; }
    .CodeMirror { flex: 1; height: 100% !important; font-size: 14px; line-height: 1.5; }
  </style>
</head>
<body>
  <div class="toolbar">
    <a href="/_admin">&larr; Dashboard</a>
    <span class="title">Editor</span>
    <button class="btn-new" onclick="newFile()">New file</button>
    <button class="btn-delete" id="btn-delete" onclick="deleteFile()" style="display:none">Delete</button>
    <span class="filepath" id="filepath"></span>
    <span class="saved-indicator" id="saved-indicator">Saved</span>
    <button class="btn-save" id="btn-save" onclick="saveFile()" disabled>Save</button>
  </div>

  <div class="main">
    <div class="sidebar">
      <div class="section-label">Files</div>
      <div class="tree" id="file-tree"></div>
    </div>
    <div class="editor-pane" id="editor-pane">
      <div class="empty-state" id="empty-state">Select a file to edit</div>
    </div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/codemirror.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/mode/javascript/javascript.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/mode/htmlmixed/htmlmixed.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/mode/xml/xml.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/mode/css/css.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/addon/mode/multiplex.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/mode/htmlembedded/htmlembedded.min.js"></script>
  <script>
    var files = <%- JSON.stringify(files) %>;
    var editor = null;
    var currentPath = null;
    var dirty = false;

    function api(action, data) {
      return fetch("/_admin/editor", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(Object.assign({ action: action }, data))
      }).then(function(r) { return r.json(); });
    }

    // Build tree structure from flat file list
    function buildTree(paths) {
      var root = {};
      for (var i = 0; i < paths.length; i++) {
        var parts = paths[i].split("/");
        var node = root;
        for (var j = 0; j < parts.length; j++) {
          if (!node[parts[j]]) {
            node[parts[j]] = j === parts.length - 1 ? null : {};
          }
          if (j < parts.length - 1) node = node[parts[j]];
        }
      }
      return root;
    }

    function renderTree(tree, container, prefix) {
      // Sort: directories first, then files
      var keys = Object.keys(tree).sort(function(a, b) {
        var aDir = tree[a] !== null ? 0 : 1;
        var bDir = tree[b] !== null ? 0 : 1;
        if (aDir !== bDir) return aDir - bDir;
        return a.localeCompare(b);
      });

      for (var i = 0; i < keys.length; i++) {
        var name = keys[i];
        var fullPath = prefix ? prefix + "/" + name : name;
        var isDir = tree[name] !== null;

        var item = document.createElement("div");
        item.className = "tree-item " + (isDir ? "tree-dir" : "tree-file");
        item.style.paddingLeft = ((prefix ? prefix.split("/").length : 0) * 0.75 + 0.5) + "rem";

        var icon = document.createElement("span");
        icon.className = "tree-icon " + (isDir ? "dir-icon" : "file-icon");
        item.appendChild(icon);

        var label = document.createElement("span");
        label.textContent = name;
        item.appendChild(label);

        container.appendChild(item);

        if (isDir) {
          var children = document.createElement("div");
          children.className = "tree-children open";
          item.classList.remove("collapsed");
          (function(it, ch) {
            it.addEventListener("click", function(e) {
              e.stopPropagation();
              ch.classList.toggle("open");
              it.classList.toggle("collapsed");
            });
          })(item, children);
          container.appendChild(children);
          renderTree(tree[name], children, fullPath);
        } else {
          item.setAttribute("data-path", fullPath);
          (function(p, el) {
            el.addEventListener("click", function(e) {
              e.stopPropagation();
              openFile(p);
            });
          })(fullPath, item);
        }
      }
    }

    function refreshTree() {
      api("list").then(function(res) {
        files = res.files;
        var treeEl = document.getElementById("file-tree");
        treeEl.innerHTML = "";
        renderTree(buildTree(files), treeEl, "");
        highlightActive();
      });
    }

    function highlightActive() {
      var items = document.querySelectorAll(".tree-file");
      for (var i = 0; i < items.length; i++) {
        items[i].classList.toggle("active", items[i].getAttribute("data-path") === currentPath);
      }
    }

    function getMode(path) {
      if (/\.mjs$/.test(path) || /\.js$/.test(path)) return "javascript";
      if (/\.ejs$/.test(path)) return { name: "htmlembedded", scriptingModeSpec: "javascript" };
      if (/\.html$/.test(path)) return "htmlmixed";
      if (/\.css$/.test(path)) return "css";
      return "htmlmixed";
    }

    function initEditor() {
      if (editor) return;
      document.getElementById("empty-state").style.display = "none";
      editor = CodeMirror(document.getElementById("editor-pane"), {
        value: "",
        theme: "dracula",
        lineNumbers: true,
        tabSize: 2,
        indentWithTabs: false,
        lineWrapping: true,
        extraKeys: {
          "Ctrl-S": function() { saveFile(); },
          "Cmd-S": function() { saveFile(); }
        }
      });
      editor.on("change", function() {
        if (!dirty) {
          dirty = true;
          document.getElementById("btn-save").disabled = false;
        }
      });
    }

    function openFile(path) {
      if (dirty && currentPath) {
        if (!confirm("Discard unsaved changes to " + currentPath + "?")) return;
      }
      api("load", { path: path }).then(function(res) {
        if (res.error) { alert("Failed to load: " + res.error); return; }
        initEditor();
        currentPath = path;
        editor.setValue(res.content);
        editor.setOption("mode", getMode(path));
        editor.clearHistory();
        dirty = false;
        document.getElementById("btn-save").disabled = true;
        document.getElementById("filepath").textContent = path;
        document.getElementById("btn-delete").style.display = "";
        highlightActive();
        editor.focus();
      });
    }

    function saveFile() {
      if (!currentPath || !editor) return;
      var btn = document.getElementById("btn-save");
      btn.disabled = true;
      api("save", { path: currentPath, content: editor.getValue() }).then(function(res) {
        if (res.ok) {
          dirty = false;
          var ind = document.getElementById("saved-indicator");
          ind.classList.add("show");
          setTimeout(function() { ind.classList.remove("show"); }, 1500);
        } else {
          alert("Save failed");
          btn.disabled = false;
        }
      });
    }

    function newFile() {
      var path = prompt("File path (e.g. api/users/index.mjs):");
      if (!path) return;
      path = path.replace(/^\/+/, "");
      api("save", { path: path, content: "" }).then(function(res) {
        if (res.ok) {
          refreshTree();
          openFile(path);
        }
      });
    }

    function deleteFile() {
      if (!currentPath) return;
      if (!confirm("Delete " + currentPath + "?")) return;
      api("delete", { path: currentPath }).then(function(res) {
        if (res.ok) {
          currentPath = null;
          dirty = false;
          if (editor) editor.setValue("");
          document.getElementById("filepath").textContent = "";
          document.getElementById("btn-save").disabled = true;
          document.getElementById("btn-delete").style.display = "none";
          refreshTree();
        }
      });
    }

    // Initial render
    var treeEl = document.getElementById("file-tree");
    renderTree(buildTree(files), treeEl, "");
  </script>
</body>
</html>
