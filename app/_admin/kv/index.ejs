<%
  if (request.method === "POST") {
    let body = JSON.parse(request.body);

    if (body.action === "list") {
      let prefix = body.prefix || "";
      let entries = [];
      let end = prefix + "\x7f";
      let raw = kv.range(prefix, end, 10000);
      if (raw) {
        for (let entry of raw) {
          entries.push({ key: entry.key, size: entry.value_size });
        }
      }
      return { entries };
    }

    if (body.action === "get") {
      let val = kv.get(body.key);
      if (val === undefined || val === null) {
        response.status(404);
        return { error: "not found" };
      }
      // Encode as array of char codes so binary data survives JSON
      let codes = [];
      for (let i = 0; i < val.length; i++) codes.push(val.charCodeAt(i));
      return { raw: codes };
    }

    if (body.action === "delete") {
      kv.delete(body.key);
      return { ok: true };
    }

    response.status(400);
    return { error: "unknown action" };
  }
%>
<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>KV Store - shift-js admin</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; overflow: hidden; font-family: system-ui, sans-serif; background: #1e1e2e; color: #cdd6f4; }

    .toolbar { display: flex; align-items: center; gap: 1rem; padding: 0.5rem 1rem; background: #181825; border-bottom: 1px solid #313244; height: 44px; }
    .toolbar a { color: #89b4fa; text-decoration: none; font-weight: 500; font-size: 0.9rem; }
    .toolbar a:hover { text-decoration: underline; }
    .toolbar .title { font-weight: 600; font-size: 0.95rem; color: #cdd6f4; }

    .main { display: flex; height: calc(100% - 44px); }

    .sidebar { width: 320px; min-width: 220px; background: #181825; border-right: 1px solid #313244; display: flex; flex-direction: column; flex-shrink: 0; }
    .sidebar .prefix-bar { padding: 0.5rem; border-bottom: 1px solid #313244; }
    .sidebar .prefix-bar input { width: 100%; padding: 0.4rem 0.6rem; background: #313244; border: 1px solid #45475a; border-radius: 4px; color: #cdd6f4; font-size: 0.85rem; font-family: monospace; outline: none; }
    .sidebar .prefix-bar input:focus { border-color: #89b4fa; }
    .sidebar .key-count { padding: 0.3rem 0.75rem; font-size: 0.7rem; color: #6c7086; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; border-bottom: 1px solid #313244; }
    .key-list { flex: 1; overflow-y: auto; }
    .key-item { padding: 0.35rem 0.75rem; cursor: pointer; font-size: 0.8rem; font-family: monospace; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: flex; justify-content: space-between; align-items: center; }
    .key-item:hover { background: #313244; }
    .key-item.active { background: #45475a; color: #89b4fa; }
    .key-item .size { color: #6c7086; font-size: 0.7rem; flex-shrink: 0; margin-left: 0.5rem; }

    .value-pane { flex: 1; display: flex; flex-direction: column; min-width: 0; }
    .value-header { display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem 1rem; background: #181825; border-bottom: 1px solid #313244; flex-shrink: 0; }
    .value-header .key-path { font-family: monospace; font-size: 0.85rem; color: #a6adc8; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .mode-btn { padding: 0.25rem 0.6rem; border: 1px solid #45475a; background: none; color: #a6adc8; border-radius: 3px; font-size: 0.75rem; cursor: pointer; font-family: system-ui, sans-serif; }
    .mode-btn:hover { border-color: #89b4fa; color: #89b4fa; }
    .mode-btn.active { background: #89b4fa; color: #1e1e2e; border-color: #89b4fa; }
    .btn-del { padding: 0.25rem 0.6rem; border: 1px solid #f38ba8; background: none; color: #f38ba8; border-radius: 3px; font-size: 0.75rem; cursor: pointer; }
    .btn-del:hover { background: rgba(243,139,168,0.1); }

    .value-body { flex: 1; overflow: auto; padding: 1rem; }
    .value-body pre { font-family: "SF Mono", "Fira Code", monospace; font-size: 13px; line-height: 1.6; white-space: pre-wrap; word-break: break-all; color: #cdd6f4; }
    .value-body .hex-view { font-family: "SF Mono", "Fira Code", monospace; font-size: 12px; line-height: 1.7; color: #cdd6f4; }
    .hex-view .offset { color: #6c7086; }
    .hex-view .hex-bytes { color: #89b4fa; }
    .hex-view .ascii { color: #a6e3a1; }
    .empty-state { display: flex; align-items: center; justify-content: center; height: 100%; color: #6c7086; font-size: 0.95rem; }
  </style>
</head>
<body>
  <div class="toolbar">
    <a href="/_admin">&larr; Dashboard</a>
    <span class="title">KV Store</span>
  </div>

  <div class="main">
    <div class="sidebar">
      <div class="prefix-bar">
        <input type="text" id="prefix-input" placeholder="Key prefix filter..." value="">
      </div>
      <div class="key-count" id="key-count">0 keys</div>
      <div class="key-list" id="key-list"></div>
    </div>
    <div class="value-pane">
      <div class="value-header" id="value-header" style="display:none">
        <span class="key-path" id="key-path"></span>
        <button class="mode-btn active" data-mode="text">Text</button>
        <button class="mode-btn" data-mode="json">JSON</button>
        <button class="mode-btn" data-mode="hex">Hex</button>
        <button class="btn-del" id="btn-del" onclick="deleteKey()">Delete</button>
      </div>
      <div class="value-body" id="value-body">
        <div class="empty-state" id="empty-state">Select a key to view its value</div>
      </div>
    </div>
  </div>

  <script>
    var currentKey = null;
    var currentRaw = null; // array of char codes
    var currentMode = "text";
    var debounceTimer = null;

    function api(action, data) {
      return fetch("/_admin/kv", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(Object.assign({ action: action }, data))
      }).then(function(r) { return r.json(); });
    }

    function formatSize(n) {
      if (n < 1024) return n + " B";
      if (n < 1024 * 1024) return (n / 1024).toFixed(1) + " KB";
      return (n / (1024 * 1024)).toFixed(1) + " MB";
    }

    function loadKeys() {
      var prefix = document.getElementById("prefix-input").value;
      api("list", { prefix: prefix }).then(function(res) {
        var list = document.getElementById("key-list");
        list.innerHTML = "";
        document.getElementById("key-count").textContent = res.entries.length + " key" + (res.entries.length !== 1 ? "s" : "");
        for (var i = 0; i < res.entries.length; i++) {
          var item = document.createElement("div");
          item.className = "key-item" + (res.entries[i].key === currentKey ? " active" : "");
          var name = document.createElement("span");
          name.textContent = res.entries[i].key;
          name.title = res.entries[i].key;
          var size = document.createElement("span");
          size.className = "size";
          size.textContent = formatSize(res.entries[i].size);
          item.appendChild(name);
          item.appendChild(size);
          (function(k) {
            item.addEventListener("click", function() { loadValue(k); });
          })(res.entries[i].key);
          list.appendChild(item);
        }
      });
    }

    function loadValue(key) {
      currentKey = key;
      api("get", { key: key }).then(function(res) {
        if (res.error) { alert("Not found"); return; }
        currentRaw = res.raw;
        document.getElementById("value-header").style.display = "";
        document.getElementById("key-path").textContent = key;
        document.getElementById("key-path").title = key;
        var es = document.getElementById("empty-state");
        if (es) es.style.display = "none";
        renderValue();
        // Highlight active key
        var items = document.querySelectorAll(".key-item");
        for (var i = 0; i < items.length; i++) {
          items[i].classList.toggle("active", items[i].firstChild.textContent === key);
        }
      });
    }

    function rawToString(raw) {
      // Decode in chunks to avoid call stack overflow
      var result = "";
      for (var i = 0; i < raw.length; i += 4096) {
        var chunk = raw.slice(i, i + 4096);
        result += String.fromCharCode.apply(null, chunk);
      }
      return result;
    }

    function renderValue() {
      var body = document.getElementById("value-body");

      if (currentMode === "text") {
        var pre = document.createElement("pre");
        pre.textContent = rawToString(currentRaw);
        body.innerHTML = "";
        body.appendChild(pre);

      } else if (currentMode === "json") {
        var text = rawToString(currentRaw);
        var pre = document.createElement("pre");
        try {
          pre.textContent = JSON.stringify(JSON.parse(text), null, 2);
        } catch (e) {
          pre.textContent = "(not valid JSON)\n\n" + text;
        }
        body.innerHTML = "";
        body.appendChild(pre);

      } else if (currentMode === "hex") {
        body.innerHTML = "";
        var container = document.createElement("div");
        container.className = "hex-view";
        var raw = currentRaw;
        for (var off = 0; off < raw.length; off += 16) {
          var line = document.createElement("div");
          // Offset
          var offsetSpan = document.createElement("span");
          offsetSpan.className = "offset";
          offsetSpan.textContent = ("00000000" + off.toString(16)).slice(-8) + "  ";
          line.appendChild(offsetSpan);
          // Hex bytes
          var hexSpan = document.createElement("span");
          hexSpan.className = "hex-bytes";
          var hexParts = [];
          var asciiParts = [];
          for (var i = 0; i < 16; i++) {
            if (off + i < raw.length) {
              var b = raw[off + i];
              hexParts.push(("0" + b.toString(16)).slice(-2));
              asciiParts.push(b >= 32 && b <= 126 ? String.fromCharCode(b) : ".");
            } else {
              hexParts.push("  ");
              asciiParts.push(" ");
            }
            if (i === 7) hexParts.push("");
          }
          hexSpan.textContent = hexParts.join(" ") + "  ";
          line.appendChild(hexSpan);
          // ASCII
          var asciiSpan = document.createElement("span");
          asciiSpan.className = "ascii";
          asciiSpan.textContent = "|" + asciiParts.join("") + "|";
          line.appendChild(asciiSpan);
          container.appendChild(line);
        }
        body.appendChild(container);
      }
    }

    function deleteKey() {
      if (!currentKey) return;
      if (!confirm("Delete key: " + currentKey + "?")) return;
      api("delete", { key: currentKey }).then(function() {
        currentKey = null;
        currentRaw = null;
        document.getElementById("value-header").style.display = "none";
        document.getElementById("value-body").innerHTML = '<div class="empty-state">Select a key to view its value</div>';
        loadKeys();
      });
    }

    // Mode buttons
    var modeBtns = document.querySelectorAll(".mode-btn");
    for (var i = 0; i < modeBtns.length; i++) {
      (function(btn) {
        btn.addEventListener("click", function() {
          currentMode = btn.getAttribute("data-mode");
          for (var j = 0; j < modeBtns.length; j++) {
            modeBtns[j].classList.toggle("active", modeBtns[j] === btn);
          }
          if (currentRaw) renderValue();
        });
      })(modeBtns[i]);
    }

    // Prefix input with debounce
    document.getElementById("prefix-input").addEventListener("input", function() {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(loadKeys, 250);
    });

    // Initial load
    loadKeys();
  </script>
</body>
</html>
