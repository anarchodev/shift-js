<%
  if (request.method === "GET") {
    // GET with ?path=foo reads a single module, otherwise lists all
    let qs = request.path.split("?")[1] || "";
    let params = {};
    for (let p of qs.split("&")) {
      let [k, v] = p.split("=");
      if (k && v) params[k] = decodeURIComponent(v);
    }

    if (params.path) {
      let content = kv.get("__code/" + params.path);
      if (content === undefined || content === null) {
        response.status(404);
        return { error: "not found" };
      }
      return { path: params.path, content };
    }

    let files = [];
    let raw = kv.range("__code/", "__code/\x7f", 10000);
    if (raw) {
      for (let entry of raw) {
        files.push({ path: entry.key.slice(7), size: entry.value.length });
      }
    }
    return { files };
  }

  if (request.method === "POST") {
    let body = JSON.parse(request.body);
    let path = (body.path || "").trim();
    if (!path) {
      response.status(400);
      return { error: "path is required" };
    }

    let content = body.content;
    if (content === undefined || content === null) {
      response.status(400);
      return { error: "content is required" };
    }

    kv.put("__code/" + path, content);

    // Invalidate compiled bytecode cache
    let base = path;
    let dot = base.lastIndexOf(".");
    let slash = base.lastIndexOf("/");
    if (dot > slash) base = base.substring(0, dot);
    kv.delete("__compiled/" + base);

    return { ok: true };
  }

  if (request.method === "DELETE") {
    let body = JSON.parse(request.body);
    let path = (body.path || "").trim();
    if (!path) {
      response.status(400);
      return { error: "path is required" };
    }

    kv.delete("__code/" + path);

    let base = path;
    let dot = base.lastIndexOf(".");
    let slash = base.lastIndexOf("/");
    if (dot > slash) base = base.substring(0, dot);
    kv.delete("__compiled/" + base);

    return { ok: true };
  }

  response.status(405);
  return { error: "method not allowed" };
%>
